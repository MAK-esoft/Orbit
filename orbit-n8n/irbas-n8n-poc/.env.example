# ============================================================
# IRBAS WhatsApp Ingestion POC — environment variables
# Copy this file to ".env" and fill in the values.
# See README.md → "API Keys Required" for where to get each one.
# ============================================================

# --- n8n ---
# Login credentials for the n8n editor (http://localhost:5678)
N8N_BASIC_AUTH_USER=
N8N_BASIC_AUTH_PASSWORD=
# 32-char random string. Generate with: openssl rand -hex 16
N8N_ENCRYPTION_KEY=

# --- Groq API (free tier — used for AI classification) ---
# Get from https://console.groq.com -> API Keys. Model: llama-3.1-8b-instant
GROQ_API_KEY=

# --- Orbit API (single source of truth — replaces Supabase) ---
# Base URL of the Orbit API including the /api prefix.
# Local dev: http://host.docker.internal:4000/api (so the n8n container can
# reach the Orbit API running on the host). Prod: your Orbit API URL + /api.
ORBIT_API_BASE_URL=http://host.docker.internal:4000/api
# Shared secret sent as X-Integration-Key. MUST match INTEGRATION_API_KEY in
# the Orbit API's .env. Generate with: openssl rand -hex 32
INTEGRATION_API_KEY=

# --- Gmail / Email inbox for bank notifications (optional for basic POC) ---
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
# "from" address on the bank transaction alert emails (e.g. alerts@hbl.com)
IRBAS_BANK_EMAIL=

# --- WhatsApp Business API (production only — mock used in POC) ---
# For the POC, WHATSAPP_VERIFY_TOKEN is used to authenticate the mock scripts.
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Slack bot token (xoxb-...) — needed to download Slack image files (requires files:read scope)
SLACK_BOT_TOKEN=

# OpenAI API key (gpt-4o vision) for image extraction
OPENAI_API_KEY=
