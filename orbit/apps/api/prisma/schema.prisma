// Orbit — Prisma schema
// Mirrors orbit-dev-spec.md §7. PostgreSQL with native UUIDs.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  SUPER_ADMIN
  ADMIN
  RO_USER
}

enum PaymentType {
  BANK_TRANSFER
  CASH_DEPOSIT
  CHEQUE
  OTHER
}

// Category / purpose of the proof (distinct from the payment method above).
enum RequestType {
  DEPOSIT
  EXPENSE
  SALARY_DISBURSEMENT
  VENDOR_PAYMENT
  OTHER
}

enum SubmissionStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

// Where a submission originated. APP = created in the Orbit web app;
// WHATSAPP / SLACK = ingested by the background n8n workflow.
enum SubmissionSource {
  APP
  WHATSAPP
  SLACK
}

// Lifecycle of the n8n enrichment (AI extraction) attached to a submission.
//  NONE     = no enrichment expected (legacy / not dispatched)
//  PENDING  = dispatched to the workflow, awaiting the extraction callback
//  ENRICHED = extraction received and attached
//  FAILED   = the workflow reported an error
enum EnrichmentStatus {
  NONE
  PENDING
  ENRICHED
  FAILED
}

// Direction of a manual ledger entry created by an admin.
//  CREDIT = money the RO has put toward IRBAS (reduces what they owe)
//  DEBIT  = a charge to the RO, e.g. stock delivered (increases what they owe)
enum AdjustmentType {
  CREDIT
  DEBIT
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model RegionalOffice {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  code      String   @unique @db.VarChar(50) // e.g. "RO-LHR-01"
  city      String?  @db.VarChar(100)
  region    String?  @db.VarChar(100)
  isActive  Boolean  @default(true) @map("is_active")
  // Channel identifiers used by the n8n workflow to map an inbound
  // WhatsApp group / Slack channel back to this office.
  whatsappGroupId String? @unique @map("whatsapp_group_id") @db.VarChar(255)
  slackChannelId  String? @unique @map("slack_channel_id") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users       User[]
  submissions PaymentSubmission[]
  adjustments LedgerAdjustment[]

  @@map("regional_offices")
}

model User {
  id                  String    @id @default(uuid()) @db.Uuid
  email               String    @unique @db.VarChar(255)
  passwordHash        String?   @map("password_hash") @db.VarChar(255) // null until activated
  fullName            String    @map("full_name") @db.VarChar(255)
  role                Role
  roId                String?   @map("ro_id") @db.Uuid // null for admin/super_admin
  isActive            Boolean   @default(true) @map("is_active")
  setupToken          String?   @map("setup_token") @db.VarChar(255) // hashed
  setupTokenExpiresAt DateTime? @map("setup_token_expires_at")
  resetToken          String?   @map("reset_token") @db.VarChar(255) // hashed
  resetTokenExpiresAt DateTime? @map("reset_token_expires_at")
  lastLoginAt         DateTime? @map("last_login_at")
  createdById         String?   @map("created_by") @db.Uuid
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  regionalOffice RegionalOffice? @relation(fields: [roId], references: [id])
  createdBy      User?           @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdUsers   User[]          @relation("UserCreatedBy")

  submissions    PaymentSubmission[]        @relation("SubmittedBy")
  statusChanges  SubmissionStatusHistory[]  @relation("ChangedBy")
  notifications  Notification[]
  refreshTokens  RefreshToken[]
  adjustments    LedgerAdjustment[]         @relation("AdjustmentCreatedBy")

  @@index([roId])
  @@index([role])
  @@map("users")
}

model PaymentSubmission {
  id                     String           @id @default(uuid()) @db.Uuid
  roId                   String           @map("ro_id") @db.Uuid
  submittedById          String           @map("submitted_by") @db.Uuid
  requestType            RequestType      @default(OTHER) @map("request_type")
  paymentType            PaymentType      @map("payment_type")
  paymentTypeNote        String?          @map("payment_type_note") @db.VarChar(255)
  // Nullable: workflow-originated requests may not have a confirmed amount yet
  // (admin sets/confirms it before approval).
  amount                 Decimal?         @db.Decimal(12, 2)
  paymentDate            DateTime         @map("payment_date") @db.Date
  bankName               String?          @map("bank_name") @db.VarChar(255)
  referenceNumber        String?          @map("reference_number") @db.VarChar(255)
  notes                  String?          @db.Text
  // Nullable: text-only WhatsApp/Slack messages have no attachment. App
  // submissions still require a file (enforced in SubmissionsService.create).
  attachmentPath         String?          @map("attachment_path") @db.VarChar(500)
  attachmentOriginalName String?          @map("attachment_original_name") @db.VarChar(255)
  attachmentMimeType     String?          @map("attachment_mime_type") @db.VarChar(100)
  source                 SubmissionSource @default(APP)
  enrichmentStatus       EnrichmentStatus @default(NONE) @map("enrichment_status")
  // Original sender (phone number / Slack user id) for workflow-originated rows.
  senderRef              String?          @map("sender_ref") @db.VarChar(255)
  status                 SubmissionStatus @default(SUBMITTED)
  version                Int              @default(1)
  parentId               String?          @map("parent_id") @db.Uuid
  createdAt              DateTime         @default(now()) @map("created_at")
  updatedAt              DateTime         @updatedAt @map("updated_at")

  regionalOffice RegionalOffice            @relation(fields: [roId], references: [id])
  submittedBy    User                      @relation("SubmittedBy", fields: [submittedById], references: [id])
  parent         PaymentSubmission?        @relation("Resubmission", fields: [parentId], references: [id])
  resubmissions  PaymentSubmission[]       @relation("Resubmission")
  history        SubmissionStatusHistory[]
  notifications  Notification[]
  extraction     SubmissionExtraction?
  workflowMessage WorkflowMessage?

  @@index([roId])
  @@index([status])
  @@index([submittedById])
  @@index([parentId])
  @@index([source])
  @@map("payment_submissions")
}

// AI-extracted data attached to a submission by the n8n workflow. Kept in a
// separate table so it is always presented as distinct "Extracted Information",
// never merged into the user-entered submission fields.
model SubmissionExtraction {
  id                    String   @id @default(uuid()) @db.Uuid
  submissionId          String   @unique @map("submission_id") @db.Uuid
  classification        String   @db.VarChar(50) // payment_proof | expense_proof | unrecognised | ...
  extractedAmount       Decimal? @map("extracted_amount") @db.Decimal(12, 2)
  extractedPaymentMethod String? @map("extracted_payment_method") @db.VarChar(50)
  slipRef               String?  @map("slip_ref") @db.VarChar(255)
  merchant              String?  @db.VarChar(255)
  description           String?  @db.Text
  bankEmailMatch        Boolean  @default(false) @map("bank_email_match")
  bankEmailAmount       Decimal? @map("bank_email_amount") @db.Decimal(12, 2)
  bankEmailTimestamp    DateTime? @map("bank_email_timestamp")
  confidence            String?  @db.VarChar(50)
  model                 String?  @db.VarChar(100) // AI model used (e.g. gpt-4o, llama-3.1-8b-instant)
  rawResponse           Json     @map("raw_response")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  submission PaymentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@map("submission_extractions")
}

// Raw inbound message log for the n8n workflow (replaces the Supabase
// whatsapp_messages table). Every message is recorded before processing.
model WorkflowMessage {
  id               String           @id @default(uuid()) @db.Uuid
  source           SubmissionSource
  senderRef        String?          @map("sender_ref") @db.VarChar(255)
  channelId        String?          @map("channel_id") @db.VarChar(255) // WhatsApp group id / Slack channel id
  messageText      String?          @map("message_text") @db.Text
  mediaUrl         String?          @map("media_url") @db.Text
  mediaMime        String?          @map("media_mime") @db.VarChar(100)
  rawPayload       Json             @map("raw_payload")
  classification   String?          @db.VarChar(50)
  processingStatus String           @default("pending") @map("processing_status") @db.VarChar(50)
  submissionId     String?          @unique @map("submission_id") @db.Uuid
  createdAt        DateTime         @default(now()) @map("created_at")

  submission PaymentSubmission? @relation(fields: [submissionId], references: [id])

  @@index([processingStatus])
  @@map("workflow_messages")
}

model SubmissionStatusHistory {
  id           String            @id @default(uuid()) @db.Uuid
  submissionId String            @map("submission_id") @db.Uuid
  fromStatus   SubmissionStatus? @map("from_status")
  toStatus     SubmissionStatus  @map("to_status")
  changedById  String            @map("changed_by") @db.Uuid
  reason       String?           @db.Text // mandatory when toStatus = REJECTED
  createdAt    DateTime          @default(now()) @map("created_at")

  submission PaymentSubmission @relation(fields: [submissionId], references: [id])
  changedBy  User              @relation("ChangedBy", fields: [changedById], references: [id])

  @@index([submissionId])
  @@map("submission_status_history")
}

model Notification {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  type         String   @db.VarChar(100) // SUBMISSION_RECEIVED, STATUS_CHANGED, PROOF_REJECTED, PROOF_RESUBMITTED
  title        String   @db.VarChar(255)
  body         String?  @db.Text
  submissionId String?  @map("submission_id") @db.Uuid
  isRead       Boolean  @default(false) @map("is_read")
  createdAt    DateTime @default(now()) @map("created_at")

  user       User               @relation(fields: [userId], references: [id])
  submission PaymentSubmission? @relation(fields: [submissionId], references: [id])

  @@index([userId, isRead])
  @@map("notifications")
}

model LedgerAdjustment {
  id            String         @id @default(uuid()) @db.Uuid
  roId          String         @map("ro_id") @db.Uuid
  type          AdjustmentType
  amount        Decimal        @db.Decimal(12, 2)
  description   String         @db.Text
  effectiveDate DateTime       @map("effective_date") @db.Date
  createdById   String         @map("created_by") @db.Uuid
  createdAt     DateTime       @default(now()) @map("created_at")

  regionalOffice RegionalOffice @relation(fields: [roId], references: [id])
  createdBy      User           @relation("AdjustmentCreatedBy", fields: [createdById], references: [id])

  @@index([roId])
  @@map("ledger_adjustments")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @map("token_hash") @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  isRevoked Boolean  @default(false) @map("is_revoked")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}
