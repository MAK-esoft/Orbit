# ============================================================================
# Orbit — Environment Variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ============================================================================

# ----------------------------------------------------------------------------
# Database (PostgreSQL)
# In Docker Compose, host is the service name `postgres`. Locally, `localhost`.
# ----------------------------------------------------------------------------
# Host port is 5440 (mapped to container 5432 in docker-compose) to avoid clashes.
DATABASE_URL=postgresql://orbit:orbit@localhost:5440/orbit?schema=public
POSTGRES_USER=orbit
POSTGRES_PASSWORD=orbit
POSTGRES_DB=orbit

# ----------------------------------------------------------------------------
# Auth / JWT
# Generate strong secrets, e.g.: openssl rand -base64 48
# ----------------------------------------------------------------------------
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Token lifetimes (account setup & password reset), in hours
SETUP_TOKEN_EXPIRES_HOURS=48
RESET_TOKEN_EXPIRES_HOURS=1

# bcrypt cost factor
BCRYPT_SALT_ROUNDS=12

# ----------------------------------------------------------------------------
# Email (SMTP) — used ONLY for account setup & password reset
# Dev: Gmail SMTP / Mailtrap. Prod: Brevo / Mailjet.
# ----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@orbit.irbas.com

# ----------------------------------------------------------------------------
# Redis (notifications, rate limiting, future sessions)
# In Docker Compose, host is the service name `redis`.
# ----------------------------------------------------------------------------
# Host port is 6380 (mapped to container 6379 in docker-compose) to avoid clashes.
REDIS_URL=redis://localhost:6380

# ----------------------------------------------------------------------------
# File Storage
# UPLOAD_DIR is the base directory for stored attachments (relative or absolute).
# ----------------------------------------------------------------------------
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
NODE_ENV=development
API_PORT=4000
# Public base URL of the API (used to build file URLs)
API_URL=http://localhost:4000
# Frontend origin — used for CORS and for links inside setup/reset emails
FRONTEND_URL=http://localhost:3000
# Cookie domain (leave blank for localhost). Set to e.g. .orbit.irbas.com in prod.
COOKIE_DOMAIN=

# ----------------------------------------------------------------------------
# Rate limiting (auth endpoints)
# ----------------------------------------------------------------------------
RATE_LIMIT_TTL_SECONDS=60
# Global cap per IP across all routes per window (auth endpoints are stricter).
RATE_LIMIT_MAX=300

# ----------------------------------------------------------------------------
# Frontend (Next.js) — exposed at build/runtime
# Base URL the browser uses to reach the API.
# ----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4000

# ----------------------------------------------------------------------------
# Dev seed (optional) — initial SUPER_ADMIN created by `npm run seed`
# ----------------------------------------------------------------------------
SEED_SUPER_ADMIN_EMAIL=admin@orbit.irbas.com
SEED_SUPER_ADMIN_PASSWORD=ChangeMe123!
SEED_SUPER_ADMIN_NAME=Orbit Super Admin

# ----------------------------------------------------------------------------
# n8n workflow integration (background ingestion + enrichment)
# ----------------------------------------------------------------------------
# Shared secret required on every /integrations/* call (sent as X-Integration-Key).
# Generate with: openssl rand -hex 32
INTEGRATION_API_KEY=
# n8n webhook that enriches app-originated submissions. Leave blank to disable
# the round-trip dispatch — the app then behaves exactly as before.
N8N_APP_SUBMISSION_WEBHOOK_URL=
# The "Workflow Bot" user id that owns workflow-originated submissions.
# Printed by `npm run seed`; copy it here.
WORKFLOW_BOT_USER_ID=
# Public base URL n8n uses to fetch attachments (e.g. a tunnel URL in dev).
# Defaults to API_URL when unset.
PUBLIC_API_BASE_URL=http://localhost:4000
